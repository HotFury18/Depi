# Copy this file to .env and adjust as needed, or export these as real
# environment variables before running medallion_pipeline.py.
# All are optional — defaults match the original localdb setup.

# SQL Server instance name
STUDENT_DB_SERVER=(localdb)\MSSQLLocalDB

# Database name (must already exist — run sql_scripts/01_... first)
STUDENT_DB_NAME=StudentPerformanceDB

# ODBC driver name as registered on your machine
STUDENT_DB_DRIVER=ODBC Driver 17 for SQL Server
